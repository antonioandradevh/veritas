{
  "manifest_version": 3,
  "name": "Ankeiro",
  "version": "1.0",
  "icons": {
    "1": "icons/logo.png"
},
  "description": "Capture questões e exporte para Anki.",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": ["*://*.tecconcursos.com.br/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://*.tecconcursos.com.br/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
