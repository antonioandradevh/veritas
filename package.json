{
  "name": "app",
  "private": true,
  "version": "1.0.0",
  "description": "VERITAS - Sistema de Estudos P2P",
  "author": "Antônio",
  "type": "module",
  "main": "electron-main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "electron .",
    "electron:build": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.pobruja.veritas",
    "productName": "VERITAS",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron-main.cjs"
    ],
    "win": {
      "target": "portable"
    }
  },
  "dependencies": {
    "cal-heatmap": "^4.2.4",
    "d3": "^7.9.0",
    "date-fns": "^4.1.0",
    "docx": "^9.6.0",
    "file-saver": "^2.0.5",
    "html-to-docx": "^1.8.0",
    "localforage": "^1.10.0",
    "pdfjs-dist": "^5.4.624",
    "peerjs": "^1.5.5",
    "react": "^19.2.0",
    "react-calendar-heatmap": "^1.10.0",
    "react-dom": "^19.2.0",
    "react-hot-toast": "^2.6.0",
    "react-pdf": "^10.4.1",
    "recharts": "^3.7.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-calendar-heatmap": "^1.9.0",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  }
}
